# LLM Providers — set the key for whichever provider you configure in .goalever/config.json
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Langfuse — agent execution tracing (optional)
# Create a free account at https://cloud.langfuse.com, then Settings → API Keys
# Leave unset to disable cloud tracing (local SQLite traces still work)
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"
